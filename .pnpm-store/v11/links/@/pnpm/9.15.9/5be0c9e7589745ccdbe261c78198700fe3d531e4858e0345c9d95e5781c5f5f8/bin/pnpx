#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
fi
# cmd-shim-target=/Users/zhangyuehan/new-demo/kanban/.pnpm-store/v11/links/@/pnpm/9.15.9/5be0c9e7589745ccdbe261c78198700fe3d531e4858e0345c9d95e5781c5f5f8/node_modules/pnpm/bin/pnpx.cjs
