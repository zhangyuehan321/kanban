# 前端：线上 API 地址（GitHub Actions Secret: VITE_API_URL）
# 本地开发留空即可，Vite 会把 /api 代理到 localhost:3001
VITE_API_URL=

# 前端：GitHub Pages 子路径（CI 自动注入，本地无需配置）
VITE_BASE_PATH=

# 后端：允许跨域的前端域名（Render 等平台环境变量）
ALLOWED_ORIGINS=http://localhost:5173,https://zhangyuehan321.github.io

# 后端：服务端口（云平台会自动注入 PORT）
PORT=3001
